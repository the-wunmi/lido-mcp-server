# Ethereum RPC endpoint (Alchemy, Infura, etc.)
LIDO_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# Hex-encoded private key for signing transactions
LIDO_PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Chain ID (REQUIRED):
#   L1: 1 = mainnet, 17000 = Holesky testnet, 560048 = Hoodi testnet (full Lido SDK — staking, wrapping, governance)
#   L2: 8453 = Base, 10 = Optimism, 42161 = Arbitrum (wstETH balance + transfer only)
#   Note: Optimism also supports rebasing stETH (balance + transfer) alongside wstETH.
# Server will refuse to start without an explicit chain ID to prevent accidental mainnet usage.
LIDO_CHAIN_ID=17000

# --- Security Guardrails (all optional) ---

# Operating mode: "full" (default) | "dry-run-only" | "read-only"
#   full         — all operations available
#   dry-run-only — write tools always simulate, dry_run cannot be set to false
#   read-only    — write tools are not registered at all
# LIDO_MODE=full

# Comma-separated allowlist of Ethereum addresses permitted as receivers/referrals.
# If set, only these addresses are accepted for receiver and referral_address params.
# If not set, only the configured wallet address is allowed.
# LIDO_ALLOWED_RECEIVERS=0xabc...,0xdef...

# Maximum ETH value per transaction. Rejects any write operation above this amount.
# LIDO_MAX_TRANSACTION_ETH=10
