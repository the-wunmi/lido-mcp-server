# Required
LIDO_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
LIDO_PRIVATE_KEY=0xYOUR_PRIVATE_KEY
# L1: 1 (mainnet), 17000 (Holesky), 560048 (Hoodi) | L2: 8453 (Base), 10 (Optimism), 42161 (Arbitrum)
LIDO_CHAIN_ID=17000

# Security guardrails (optional)
# LIDO_MODE=full                            # full | dry-run-only | read-only
# LIDO_ALLOWED_RECEIVERS=0xabc...,0xdef...  # allowlisted receiver/referral addresses
# LIDO_MAX_TRANSACTION_ETH=10               # max ETH per transaction

# Vault monitor (optional)
# MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# Telegram alerts (optional)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Email alerts (optional)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=alerts@example.com

# AI-powered alert explanations (optional)
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
