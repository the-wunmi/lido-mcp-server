{
  "name": "lido-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Lido protocol — stake ETH from any AI agent",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --outDir dist --clean",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "dev": "tsup src/index.ts --format esm --dts --outDir dist --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@lidofinance/lido-ethereum-sdk": "^4.7.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^16.4.7",
    "mathjs": "15.1.1",
    "nodemailer": "^8.0.3",
    "viem": "^2.21.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^7.0.11",
    "@vitest/coverage-v8": "^4.1.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  }
}
